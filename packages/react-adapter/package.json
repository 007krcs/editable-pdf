{
  "name": "@docsdk/react-adapter",
  "version": "0.1.0",
  "description": "React hooks and components for DocSDK",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./hooks": {
      "types": "./dist/hooks.d.ts",
      "import": "./dist/hooks.js"
    },
    "./components": {
      "types": "./dist/components.d.ts",
      "import": "./dist/components.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/hooks.ts src/components.ts --format esm --dts --external react --external react-dom",
    "clean": "rm -rf dist",
    "test": "vitest run"
  },
  "dependencies": {
    "@docsdk/core": "workspace:*",
    "@docsdk/form-engine": "workspace:*",
    "@docsdk/pdf-engine": "workspace:*",
    "@docsdk/screenshot": "workspace:^",
    "@docsdk/shared-types": "workspace:*",
    "@docsdk/signature": "workspace:*",
    "@docsdk/validation": "workspace:*",
    "@docsdk/viewer": "workspace:*"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "happy-dom": "^20.8.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
