{
  "name": "@docsdk/viewer",
  "version": "0.1.0",
  "description": "Headless rendering helpers for DocSDK",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "clean": "rm -rf dist",
    "test": "vitest run"
  },
  "dependencies": {
    "@docsdk/core": "workspace:*",
    "@docsdk/pdf-engine": "workspace:*",
    "@docsdk/shared-types": "workspace:*"
  },
  "devDependencies": {
    "happy-dom": "^20.8.3",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
