{
  "name": "@docsdk/page-ops",
  "version": "0.1.0",
  "description": "Page manipulation plugin for DocSDK (add, delete, reorder, rotate)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "clean": "rm -rf dist",
    "test": "vitest run"
  },
  "dependencies": {
    "@docsdk/shared-types": "workspace:*",
    "@docsdk/core": "workspace:*",
    "@docsdk/pdf-engine": "workspace:*",
    "pdf-lib": "^1.17.1"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
